rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myEmail() {
      return request.auth.token.email.lower();
    }
    function isApproved() {
      return isSignedIn() && exists(/databases/$(database)/documents/allowlist/$(myEmail()));
    }
    function myRole() {
      return get(/databases/$(database)/documents/allowlist/$(myEmail())).data.role;
    }
    function isAdmin() {
      return isApproved() && myRole() == 'admin';
    }
    function isAdminOrPM() {
      return isApproved() && (myRole() == 'admin' || myRole() == 'pm');
    }

    // Tickets: any approved user can read/create/update.
    // Only admins or PMs can delete (matches the process doc's access rules).
    match /tickets/{ticketId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdminOrPM();

      // Comments: any approved user can read and post.
      // A comment can be deleted by its author, or by an admin/PM.
      match /comments/{commentId} {
        allow read, create: if isApproved();
        allow delete: if isApproved() &&
          (resource.data.author.lower() == myEmail() || isAdminOrPM());
      }
    }

    // Allow list: a user can always read their own entry (so the app can
    // tell them "pending approval"). Any approved user can read the full
    // roster (needed for the assignee dropdown). Only admins can add
    // people, remove people, or change roles.
    match /allowlist/{email} {
      allow read: if isSignedIn() && myEmail() == email;
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // Access requests: a signed-in user can create/read only their own
    // request (used to power "Request access" on the pending screen).
    // Admins can read and delete any request (delete = approve or deny,
    // both happen from the Team tab).
    match /accessRequests/{email} {
      allow create, read: if isSignedIn() && myEmail() == email;
      allow read, delete: if isAdmin();
    }
  }
}
